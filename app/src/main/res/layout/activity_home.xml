<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F8">

    <ImageView android:id="@+id/wallpaperImage"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:scaleType="centerCrop" android:contentDescription="טפט"/>

    <!-- Header -->
    <LinearLayout android:id="@+id/header"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="center"
        android:paddingTop="32dp" android:paddingBottom="12dp"
        android:background="#E8EAF6">

        <TextView android:id="@+id/clockText"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#1A1A2E" android:textSize="52sp"
            android:fontFamily="sans-serif-light" android:text="00:00"/>

        <TextView android:id="@+id/dateText"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#3F51B5" android:textSize="15sp"
            android:paddingTop="2dp" android:text="יום ראשון"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="בפיקוח" android:textColor="#455A64"
            android:textSize="12sp" android:paddingTop="2dp"/>
    </LinearLayout>

    <!-- Bottom bar — הגדרות בלבד -->
    <LinearLayout android:id="@+id/bottomBar"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:gravity="center" android:background="#E8EAF6"
        android:orientation="horizontal" android:elevation="4dp">

        <TextView android:id="@+id/settingsBtn"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="⚙ הגדרות" android:textColor="#3F51B5"
            android:textSize="15sp" android:gravity="center" android:padding="12dp"/>
    </LinearLayout>

    <!-- Apps Grid -->
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/appsGrid"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:layout_below="@id/header" android:layout_above="@id/bottomBar"
        android:padding="8dp" android:scrollbars="none"/>

</RelativeLayout>
