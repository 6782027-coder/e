<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:layoutDirection="rtl"
    android:padding="16dp">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary_dark"
        android:layout_marginStart="-16dp"
        android:layout_marginEnd="-16dp" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:gravity="center"
        android:padding="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="שלבים להגדרה:"
        android:textColor="@color/accent"
        android:textSize="16sp"
        android:paddingBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1. הפעל USB Debugging במכשיר\n   (הגדרות ← אפשרויות מפתח ← USB Debugging)\n\n2. חבר את המכשיר למחשב\n\n3. הרץ את הפקודה הבאה ב-CMD:"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.4"
        android:paddingBottom="16dp" />

    <TextView
        android:id="@+id/commandText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:textColor="#00FF88"
        android:fontFamily="monospace"
        android:textSize="12sp"
        android:padding="12dp"
        android:textIsSelectable="true" />

    <Button
        android:id="@+id/btnCopy"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="העתק פקודה"
        android:backgroundTint="@color/primary"
        android:textColor="@color/text_primary"
        android:layout_marginTop="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="4. הפעל מחדש את המכשיר\n5. פתח שוב את בפיקוח — הסטטוס יתעדכן"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.4"
        android:paddingTop="16dp" />

</LinearLayout>
